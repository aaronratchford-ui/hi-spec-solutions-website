# Contact form email delivery (Resend) — https://resend.com
# Without these, the contact form still works and logs enquiries server-side,
# but does not send emails. Add them in Vercel → Project → Settings → Environment Variables.

# Your Resend API key
RESEND_API_KEY=

# Where enquiry emails are delivered (defaults to the company email if unset)
CONTACT_TO_EMAIL=hispecsolutionsltd@gmail.com

# The "from" address. Use Resend's test sender until your domain is verified,
# then switch to something like "Hi-Spec Website <enquiries@hi-spec-solutions.co.uk>"
CONTACT_FROM_EMAIL="Hi-Spec Website <onboarding@resend.dev>"
